# Rave Tracker Environment Variables
# Copy this file to .env and fill in your values
# See README.md for details on each variable

# === REQUIRED SECRETS ===

# Application secret key for token signing (unsubscribe links, CSRF)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# SMTP credentials (Brevo)
BREVO_SMTP_USERNAME=your-smtp-username
BREVO_SMTP_PASSWORD=your-smtp-password

# === OPTIONAL OVERRIDES ===

# Public URL for email links (default: http://localhost:8080)
BASE_URL=http://localhost:8080

# Generic SMTP alternative names (use instead of BREVO_* if not using Brevo)
# EMAIL_SMTP_USERNAME=your-smtp-username
# EMAIL_SMTP_PASSWORD=your-smtp-password
# EMAIL_SMTP_SERVER=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=Rave Tracker

# Alternative app config names
# APP_SECRET_KEY=your-secret-key-here
# APP_BASE_URL=http://localhost:8080

# Database and Telegram overrides
# RA_TRACKER_DB_PATH=./data/ra_tracker.db
# TELEGRAM_CHAT_ID=your-chat-id
