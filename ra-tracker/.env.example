# RA Tracker Environment Variables
# Copy this file to .env and fill in your actual values
# The .env file is gitignored for security

# === Database ===
# PostgreSQL connection URL (leave empty to use SQLite fallback)
# Supports both postgres:// and postgresql:// prefixes
# Format: postgresql://user:password@host:port/database
# Example: postgresql://ra_user:password123@localhost:5432/ra_tracker
DATABASE_URL=

# SQLite database path (used if DATABASE_URL is not set)
# RA_TRACKER_DB_PATH=./data/ra_tracker.db

# === Production Server ===
# Number of gunicorn workers (default: 4)
# Affects PostgreSQL connection pool size (pool = WEB_CONCURRENCY + 2)
WEB_CONCURRENCY=4

# Port for web server (used by Procfile and hosting providers)
PORT=8080

# === Application Security ===
# Secret key for session signing and CSRF tokens (required)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Base URL for the application (used in emails and verification links)
# Example: https://ravetracker.example.com
BASE_URL=http://localhost:8080

# === Email Configuration (Brevo SMTP) ===
# SMTP server hostname
EMAIL_SMTP_SERVER=smtp-relay.brevo.com

# SMTP port (587 for STARTTLS, 465 for SSL/TLS)
EMAIL_SMTP_PORT=587

# Brevo SMTP username (your Brevo login email)
BREVO_SMTP_USERNAME=

# Brevo SMTP password (API key from Brevo dashboard)
BREVO_SMTP_PASSWORD=

# Sender email address
EMAIL_FROM_ADDRESS=ravetracker@whotrustswho.com

# Sender display name
EMAIL_FROM_NAME=Rave Tracker

# === Telegram Bot (Optional) ===
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Default Telegram chat ID (optional, for legacy single-user mode)
# TELEGRAM_CHAT_ID=

# === Advanced Configuration ===
# Path to custom config.yaml file (default: config.yaml)
# RA_TRACKER_CONFIG=config.yaml
